<?xml version="1.0" encoding="utf-8"?>
<network-security-config>

    <!-- HTTP به سرور خودمون مجازه -->
    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="false">83.228.229.103</domain>
    </domain-config>

    <!-- HTTPS به همه جا مجازه (Google Fonts و غیره) -->
    <base-config cleartextTrafficPermitted="false">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>

</network-security-config>
